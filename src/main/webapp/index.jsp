<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sourav Das</title>

    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            font-family: Arial, sans-serif;
            color: white;
        }

        .card {
            background: rgba(255,255,255,0.08);
            padding: 40px;
            border-radius: 16px;
            text-align: center;
            width: 80%;
            max-width: 600px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        h1 {
            color: #38bdf8;
            margin-bottom: 20px;
        }

        p {
            font-size: 18px;
            line-height: 1.6;
        }

        .highlight {
            color: #22c55e;
            font-weight: bold;
        }
    </style>
</head>

<body>

<div class="card">
    <h1>Sourav Das</h1>

    <p>
        I have successfully completed the
        <span class="highlight">7 Day DevOps Challenge</span>
        with NextWork.
    </p>
</div>

</body>
</html>
